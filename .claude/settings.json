{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(node .claude/scripts/check-syntax.mjs)",
      "Bash(node .claude/scripts/check-syntax.mjs:*)",
      "Bash(node --check:*)",
      "Bash(bash .claude/hooks/session-start.sh)",
      "Bash(python3 -m http.server:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)"
    ]
  }
}
